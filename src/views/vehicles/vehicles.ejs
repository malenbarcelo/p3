<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Vehículos</h1>
    </div>

    <!--- filters --->
    <div class="filters-card">
        <div class="inputs-row">
            <% if (!locals.userLogged || locals.userLogged.id_users_categories == 1) { %>
                <div class="div-input">
                    <label class="label-std">Empresa</label>
                    <select class="input-std w-250" id="company">
                        <option value="">Todas las empresas</option>
                        <% companies.forEach(company => { %>
                            <option value="<%= company.id %>"><%= company.company %></option>                 
                        <% }) %>
                    </select>
                </div>     
            <% } %>
            
            <div class="div-input">
                <input type="text" class="input-std w-200" id="vehicle" placeholder="Buscar vehículo..." autocomplete="off">
            </div>
            
            <div id="unfilter" class="unfilter-btn">
                <i class="fa-solid fa-filter-circle-xmark"></i>
                <span>Limpiar filtros</span>
            </div>
        </div>
    </div>

    <!--- lista de vehículos --->
    <div class="table-container">
        <div class="vehicles-list-header">
            <div class="list-header-item" style="flex: 2;">VEHÍCULO</div>
            <div class="list-header-item" style="flex: 1.5;">FECHA ÚLTIMO EVENTO</div>
            <div class="list-header-item" style="flex: 1.5;">HORA ÚLTIMO EVENTO</div>
            <div class="list-header-item" style="width: 60px;"></div>
        </div>
        
        <div class="vehicles-list" id="table">
            <!-- table tooltip -->
            <div class="t-tooltip" id="vdppInfo">Ver detalle</div>
            
            <!-- Lista generada dinámicamente -->
            <div id="body"></div>
        </div>
    </div>
</div>

<!-- loader -->
<div class="loader ld-std" id="loader">
    <div class="ld-content ld-main top-55p"></div>
</div>

<!----------POPUPS---------->
<%- include('./vehiclesEDPP') %>
<%- include('./vehiclesVVPP') %>

<!----------SCRIPTS---------->
<script type="module" src="/js/vehicles/vehicles.js?v=<%= Date.now() %>"></script>

</body>
</html>